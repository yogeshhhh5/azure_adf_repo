{
	"name": "RESTIngest",
	"properties": {
		"activities": [
			{
				"name": "PokeAPI",
				"type": "WebActivity",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"method": "GET",
					"url": {
						"value": "https://pokeapi.co/api/v2/pokemon?",
						"type": "Expression"
					}
				}
			},
			{
				"name": "CopyPokemon",
				"type": "Copy",
				"dependsOn": [
					{
						"activity": "PokeAPI",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "RestSource",
						"httpRequestTimeout": "00:01:00",
						"requestInterval": "00.00:00:00.010",
						"requestMethod": "GET",
						"paginationRules": {
							"AbsoluteUrl.https://pokeapi.co/api/v2/pokemon?": "RANGE"
						}
					},
					"sink": {
						"type": "JsonSink",
						"storeSettings": {
							"type": "AzureBlobFSWriteSettings",
							"copyBehavior": "PreserveHierarchy"
						},
						"formatSettings": {
							"type": "JsonWriteSettings",
							"filePattern": "setOfObjects"
						}
					},
					"enableStaging": false
				},
				"inputs": [
					{
						"referenceName": "PokeREST",
						"type": "DatasetReference"
					}
				],
				"outputs": [
					{
						"referenceName": "PokeJSONdump",
						"type": "DatasetReference"
					}
				]
			}
		],
		"annotations": []
	}
}